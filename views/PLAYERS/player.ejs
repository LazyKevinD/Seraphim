<!DOCTYPE html>
<html data-bs-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title><%= player.nombre %></title>
    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.reflowhq.com/v2/toolkit.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Lato:300,400,700&amp;display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Aboreto&amp;display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Aclonica&amp;display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Amatic+SC&amp;display=swap">
    <link rel="stylesheet" href="/assets/css/Blockletter.css">
    <link rel="stylesheet" href="/assets/css/Orbitron.css">
    <link rel="stylesheet" href="/assets/css/Platinum%20Sign%20Over.css">
    <link rel="stylesheet" href="/assets/css/Platinum%20Sign%20Under.css">
    <link rel="stylesheet" href="/assets/css/cart.css">
    <link rel="stylesheet" href="/assets/css/fuente.css">
    <link rel="stylesheet" href="/assets/css/image-container.css">
    <link rel="stylesheet" href="/assets/css/Image-equipos.css">
    <link rel="stylesheet" href="/assets/css/pikaday.min.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg fixed-top portfolio-navbar gradient navbar-dark" style="background: var(--bs-emphasis-color);">
        <div class="container"><img src="/assets/img/Seraphim/Logo1.png" width="75" height="74" style="width: 50PX;height: 50PX;"><a class="navbar-brand logo" href="/" style="text-align: left;font-weight: bold;font-family: Lato, sans-serif;">SERAPHIM</a><button data-bs-toggle="collapse" class="navbar-toggler" data-bs-target="#navbarNav-1"><span class="visually-hidden" style="background: #000000;">Toggle navigation</span><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="navbarNav-1">
                <ul class="navbar-nav ms-auto" style="background: #000000;">
                    <li class="nav-item"><a class="nav-link d-flex justify-content-center align-items-center align-content-center" href="/PRODUCTOS" style="font-weight: bold;font-family: Lato, sans-serif;">SHOP</a></li>
                    <li class="nav-item d-flex align-items-center align-content-center">
                        <div class="nav-item dropdown" style="font-weight: bold;"><a class="dropdown-toggle" aria-expanded="false" data-bs-toggle="dropdown" href="#" style="color: #ffffff;">STAFF</a>
                            <div class="dropdown-menu" style="background: #000000;"><a class="dropdown-item dropdown-item" href="/STAFF/STAFF_MEMBERS" style="color: #ffffff;font-weight: bold;">ADMINISTRATORS</a><a class="dropdown-item dropdown-item" href="/STAFF/COACHES" style="color: #ffffff;font-weight: bold;">COACHES</a><a class="dropdown-item dropdown-item" href="/STAFF/STAFF_MEMBERS" style="color: #ffffff;font-weight: bold;">SPONSORS</a></div>
                        </div>
                    </li>
                    <li class="nav-item d-flex justify-content-center align-items-center align-content-center">
                        <div class="nav-item dropdown" style="font-weight: bold;"><a class="dropdown-toggle" aria-expanded="false" data-bs-toggle="dropdown" href="#" style="color: #ffffff;">JOIN THE TEAM</a>
                            <div class="dropdown-menu" style="background: #000000;"><a class="dropdown-item dropdown-item" href="https://docs.google.com/forms/d/e/1FAIpQLSdaDixe350cK4m6_p7Np-yvQo8RImbFEajzEMYTsu9jejM2GA/viewform?usp=publish-editor" style="color: #ffffff;font-weight: bold;">PLAYER</a><a class="dropdown-item" href="https://docs.google.com/forms/d/e/1FAIpQLSdY7r2d-12E820Co3sPruXM2_DKV6htubtKpTnFByJJreSDVQ/viewform?usp=dialog" style="color: #ffffff;font-weight: bold;">STAFF</a></div>
                        </div>
                    </li>
                    <li class="nav-item"><a class="nav-link d-flex justify-content-center align-items-center align-content-center" href="/EQUIPOS" style="font-weight: bold;font-family: Lato, sans-serif;">TEAMS</a></li>
                </ul>
                <div data-reflow-type="auth-button" style="font-family: Lato, sans-serif;color: var(--bs-body-bg);font-weight: bold;"></div>
            </div>
        </div>
    </nav>

    <main class="page">
        <section>
            <div class="container">
                <div class="row d-flex justify-content-center">
                    <div class="col-md-6 d-flex justify-content-center" style="width: 250px;">
                        <div style="width: 200px;height: 200px;">
                            <img class="imagen-cuadrada" src="/assets/img/Members/<%= player.nombre %>.jpeg">
                        </div>
                    </div>
                    <div class="col-md-6 d-flex justify-content-center align-items-center col-derecha" style="background: url('/assets/img/Seraphim/Banner_Vacio.jpeg') center / cover no-repeat;">
                        <h1 style="text-align: center;font-weight: bold;font-size: 50px;color: var(--bs-secondary-bg);"><%= player.nombre %></h1>
                    </div>
                </div>

                <div class="row">
                    <div class="col-xxl-7" style="width: 250px;">
                        <div>
                            <p style="text-align: center;color: var(--bs-emphasis-color);font-weight: bold;font-size: 30px;">SOCIAL<br>NETWORK</p>
                            <hr>

                            <% if (socials && socials.length > 0) { %>
                                <% socials.forEach(social => { %>
                                    <div class="row">
                                        <div class="col d-flex justify-content-center">
                                            <a href="<%= social.url %>" target="_blank" style="font-weight: bold;color: #000000;text-decoration: none;">
                                                <%= social.plataforma %>
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="row">
                                    <div class="col d-flex justify-content-center">
                                        <p class="text-center">COMING SOON</p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="col d-flex col-derecha">
                        <div class="col-derecha">
                            <p style="text-align: left;color: var(--bs-emphasis-color);font-weight: bold;font-size: 30px;">TEAMS HE BELONGS TO:</p>
                            <p style="text-align: left;color: var(--bs-emphasis-color);font-weight: bold;font-size: 15px;"><%= player.team %></p>
                            <hr>
                            <p style="text-align: left;color: var(--bs-emphasis-color);font-weight: bold;font-size: 30px;">PLAYER COMMENTS:</p>
                            <p style="text-align: left;color: var(--bs-emphasis-color);font-weight: bold;font-size: 15px;white-space: pre-line;"><%= player.comentario %></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="/assets/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/bs-init.js"></script>
    <script src="/assets/js/pikaday.min.js"></script>
    <script src="/assets/js/theme.js"></script>
</body>

</html>