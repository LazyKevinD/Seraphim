<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Acceso Denegado - SERAPHIM</title>

    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fuente.css">
</head>

<body style="background:#000;min-height:100vh;">

    <main class="d-flex justify-content-center align-items-center text-center"
          style="min-height:100vh;background:url('/assets/img/Seraphim/Banner_Vacio.jpeg') center / cover no-repeat;">

        <div class="card shadow-lg"
             style="width:430px;border-radius:20px;background:rgba(255,255,255,0.95);">

            <div class="card-body p-4">

                <img src="/assets/img/Seraphim/Logo1.png"
                     style="width:90px;height:90px;">

                <h1 class="mt-3 mb-0"
                    style="font-size:70px;font-weight:bold;color:#dc3545;">
                    403
                </h1>

                <h4 class="mt-2"
                    style="font-weight:bold;color:#000;">
                    Acceso Denegado
                </h4>

                <p class="text-muted mt-3">
                    No tienes permisos para acceder a esta sección.
                </p>

                <% if (user) { %>

                    <p class="fw-bold">
                        <%= user.usuario %><br>
                    </p>

                <% } %>

                <a href="/"
                   class="btn btn-dark w-100 mt-3">
                    VOLVER AL INICIO
                </a>

                <% if (user) { %>

                    <a href="/logout"
                       class="btn btn-outline-dark w-100 mt-2">
                        CERRAR SESIÓN
                    </a>

                <% } else { %>

                    <a href="/login"
                       class="btn btn-outline-dark w-100 mt-2">
                        INICIAR SESIÓN
                    </a>

                <% } %>

            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>