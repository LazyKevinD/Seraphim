<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <title>Jugador por agregar</title>

    <%- include('../partials/head') %>
</head>

<body>
<%- include('../partials/navbar') %>

<main class="page" style="padding-top:120px; min-height:100vh; background:#111; color:white;">
    <section class="container text-center d-flex flex-column justify-content-center align-items-center" style="min-height:70vh;">

        <h1 style="font-weight:bold; font-size:4rem;">
            JUGADOR POR AGREGAR
        </h1>

        <h3 style="font-weight:bold; color:#aaa;">
            REGISTRO PENDIENTE
        </h3>

        <p class="mt-3" style="max-width:600px;">
            El perfil de este jugador todavía no ha sido agregado al sistema.
        </p>

        <p style="color:#777;">
            Slug solicitado: <strong><%= slug %></strong>
        </p>

        <div class="mt-4">
            <a href="/TEAMS" class="btn btn-light me-2">
                Volver a equipos
            </a>

            <% if (user && user.rol === 'ADMIN') { %>
                <a href="/admin/jugadores" class="btn btn-outline-light">
                    Agregar jugador
                </a>
            <% } %>
        </div>

    </section>
</main>

    <%- include('../PARTIALS/footer') %>
    <%- include('../PARTIALS/scripts') %>
</body>
</html>