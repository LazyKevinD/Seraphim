<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">

    <title>Dashboard</title>

    <link rel="stylesheet"
          href="/assets/bootstrap/css/bootstrap.min.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<%- include('../partials/navbar') %>

<div class="container mt-5 pt-5">

    <h1>Dashboard SERAPHIM</h1>

    <div class="card mt-4">
        <div class="card-body">

            <canvas id="graficaRoles"></canvas>

        </div>
    </div>

</div>

<script>

const roles = <%- JSON.stringify(roles) %>;

const etiquetas = roles.map(r => r.rol);
const cantidades = roles.map(r => parseInt(r.total));

const ctx = document.getElementById('graficaRoles');

new Chart(ctx, {

    type: 'bar',

    data: {

        labels: etiquetas,

        datasets: [{

            label: 'Usuarios por Rol',

            data: cantidades

        }]
    }
});

</script>

    <%- include('../PARTIALS/scripts') %>
</body>
</html>