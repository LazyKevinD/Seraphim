<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fuente.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body style="background:#f4f4f4;">

<%- include('../partials/navbar') %>

<main class="container" style="padding-top:120px; padding-bottom:50px;">

    <div class="mb-4">
        <h1 style="font-weight:bold;color:#000;">DASHBOARD SERAPHIM</h1>
        <p class="text-muted">Panel de administración y accesos rápidos.</p>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <a href="/admin/jugadores" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Jugadores</h4>
                        <p class="text-muted mb-0">Administrar perfiles de jugadores.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/equipos" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Equipos</h4>
                        <p class="text-muted mb-0">Agregar, editar o eliminar equipos.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/redes" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Redes Sociales</h4>
                        <p class="text-muted mb-0">Administrar plataformas sociales.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/jugador-redes" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Redes de Jugador</h4>
                        <p class="text-muted mb-0">Asignar URLs sociales a jugadores.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/miembros-equipo" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Miembros Equipo</h4>
                        <p class="text-muted mb-0">Relacionar jugadores con equipos.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/usuarios" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Usuarios</h4>
                        <p class="text-muted mb-0">Asignar permisos y roles.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/reporte-vista" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Reporte VIEW</h4>
                        <p class="text-muted mb-0">Ver consulta multitabla con JOIN.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/admin/reporte-vista/excel" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Descargar Excel</h4>
                        <p class="text-muted mb-0">Generar reporte desde la base de datos.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="/" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-dark">
                    <div class="card-body">
                        <h4 class="text-dark fw-bold">Volver al sitio</h4>
                        <p class="text-muted mb-0">Regresar a la página principal.</p>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h4 class="fw-bold text-dark">Gráfica de usuarios por rol</h4>
            <canvas id="graficaRoles"></canvas>
        </div>
    </div>

</main>

<script>
const roles = <%- JSON.stringify(roles || []) %>;

const etiquetas = roles.map(r => r.rol);
const cantidades = roles.map(r => parseInt(r.total));

const ctx = document.getElementById('graficaRoles');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: etiquetas,
        datasets: [{
            label: 'Usuarios por Rol',
            data: cantidades
        }]
    }
});
</script>

<%- include('../partials/scripts') %>

</body>
</html>