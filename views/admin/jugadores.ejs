    <!DOCTYPE html>
    <html data-bs-theme="light">
    <head>
        <title>ABCC Jugadores</title>
    <%- include('../partials/head') %>
    </head>

    <body class="d-flex flex-column min-vh-100">
    <%- include('../partials/navbar') %>

    <main class="page" style="padding-top:120px;background:#fff;min-height:100vh;">
        <section>
            <div class="container">
                <h1 style="font-weight:bold;color:#000;">ABCC JUGADORES</h1>
                <hr>

                <% if (mensaje) { %>
                    <div id="mensaje-alerta" class="alert alert-<%= tipo %> alert-dismissible fade show" role="alert">
                        <%= mensaje %>
                        <button type="button" class="btn-close" onclick="cerrarAlerta()"></button>
                    </div>
                <% } %>

                <form action="/admin/jugadores/agregar" method="POST" class="mb-4 p-3 border rounded">
                    <h4 style="font-weight:bold;">Agregar jugador</h4>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="slug">Slug</label>
                            <input class="form-control" id="slug" name="slug" placeholder="DISTINTIVO (EJ: AKROMIC)" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label" for="nombre">Nombre</label>
                            <input class="form-control" id="nombre" name="nombre" placeholder="NAMETAG (EJ: AKROMIC)" required>
                        </div>

                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-dark w-100" type="submit">AGREGAR</button>
                        </div>
                    </div>
                    

                    <div class="mt-3">
                        <label class="form-label" style="font-weight:bold;">Equipos</label>

                        <div class="row">
                            <% equipos.forEach(equipo => { %>
                                <div class="col-md-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="teams" value="<%= equipo.nombre_equipo %>" id="add_<%= equipo.id %>">
                                        <label class="form-check-label" for="add_<%= equipo.id %>">
                                            <%= equipo.nombre_equipo %>
                                        </label>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label" for="comentario">Comentario</label>
                        <textarea class="form-control" id="comentario" name="comentario" placeholder="COMENTARIO DADO POR EL JUGADOR (EJ: SOY EL MEJOR)"></textarea>
                    </div>
                </form>

                <div class="mb-3">
                    <label class="form-label" for="buscarJugador" style="font-weight:bold;">Buscar jugador</label>
                    <input type="text" id="buscarJugador" class="form-control" placeholder="ESCRIBE ALGO PARA BUSCAR ENTRE LOS JUGADORES...">
                </div>

                <div class="table-responsive">
                    <table id="tablaAdmin" class="table table-bordered table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Slug</th>
                                <th>Nombre</th>
                                <th>Equipos</th>
                                <th>Comentario</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% players.forEach(player => { %>
                                <tr class="fila-jugador">
                                    <form action="/admin/jugadores/editar/<%= player.id %>" method="POST">
                                        <td><%= player.id %></td>

                                        <td>
                                            <input class="form-control" name="slug" value="<%= player.slug %>">
                                        </td>

                                        <td>
                                            <input class="form-control" name="nombre" value="<%= player.nombre %>">
                                        </td>

                                        <td>
                                            <% equipos.forEach(equipo => { %>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="teams" value="<%= equipo.nombre_equipo %>" id="edit_<%= player.id %>_<%= equipo.id %>" <%= player.team && player.team.includes(equipo.nombre_equipo) ? 'checked' : '' %>>
                                                    <label class="form-check-label" for="edit_<%= player.id %>_<%= equipo.id %>">
                                                        <%= equipo.nombre_equipo %>
                                                    </label>
                                                </div>
                                            <% }) %>
                                        </td>

                                        <td>
                                            <textarea class="form-control" name="comentario"><%= player.comentario %></textarea>
                                        </td>

                                        <td>
                                            <button class="btn btn-warning btn-sm mb-1 w-100" type="submit">Editar</button>
                                    </form>

                                            <form action="/admin/jugadores/eliminar/<%= player.id %>" method="POST" onsubmit="return confirmarEliminar('<%= player.nombre %>')">
                                                <input type="hidden" name="nombre" value="<%= player.nombre %>">
                                                <button class="btn btn-danger btn-sm w-100" type="submit">Eliminar</button>
                                            </form>
                                        </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <script>
    function confirmarEliminar(nombre) {
        return confirm(`¿Estás seguro que quieres eliminar a este jugador: ${nombre}?`);
    }

    function cerrarAlerta() {
        const alerta = document.getElementById('mensaje-alerta');

        if (alerta) {
            alerta.remove();
        }

        if (window.location.search.includes('mensaje=')) {
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    }

    const buscarJugador = document.getElementById('buscarJugador');

    if (buscarJugador) {
        buscarJugador.addEventListener('keyup', function () {
            const texto = this.value.toLowerCase();
            const filas = document.querySelectorAll('.fila-jugador');

            filas.forEach(fila => {
                const inputs = fila.querySelectorAll('input, textarea');
                let contenido = fila.innerText.toLowerCase();

                inputs.forEach(input => {
                    contenido += ' ' + input.value.toLowerCase();
                });

                fila.style.display = contenido.includes(texto) ? '' : 'none';
            });
        });
    }

    const alerta = document.getElementById('mensaje-alerta');

    if (alerta) {
        setTimeout(() => {
            cerrarAlerta();
        }, 3000);
    }

    document.addEventListener('DOMContentLoaded', () => {
    const campos = document.querySelectorAll(
        'input[name="slug"], input[name="nombre"], textarea[name="comentario"]'
    );

    campos.forEach(campo => {
        campo.addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    });
});
    </script>

    <%- include('../partials/scripts') %>
    </body>
    </html>