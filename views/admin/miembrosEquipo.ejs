<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <title>ABCC Miembros Equipo</title>
    <%- include('../partials/head') %>
</head>

<body class="d-flex flex-column min-vh-100">
<%- include('../partials/navbar') %>

<main class="page" style="padding-top:120px;background:#fff;min-height:100vh;">
<section>
<div class="container">

    <h1 style="font-weight:bold;color:#000;">ABCC MIEMBROS EQUIPO</h1>
    <hr>

    <% if (mensaje) { %>
        <div id="mensaje-alerta" class="alert alert-<%= tipo %> alert-dismissible fade show">
            <%= mensaje %>
            <button type="button" class="btn-close" onclick="cerrarAlerta()"></button>
        </div>
    <% } %>

    <form action="/admin/miembros-equipo/agregar" method="POST" class="mb-4 p-3 border rounded">
        <h4 style="font-weight:bold;">Agregar miembro a equipo</h4>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Equipo</label>
                <select class="form-select" name="nombre_equipo" required>
                    <% equipos.forEach(equipo => { %>
                        <option value="<%= equipo.nombre_equipo %>"><%= equipo.nombre_equipo %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Integrante</label>
                <select class="form-select" name="integrante" required>
                    <% players.forEach(player => { %>
                        <option value="<%= player.nombre %>"><%= player.nombre %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-dark w-100" type="submit">AGREGAR</button>
            </div>
        </div>
    </form>

    <div class="mb-3">
        <label class="form-label" style="font-weight:bold;">Buscar miembro</label>
        <input type="text" id="buscar" class="form-control" placeholder="ESCRIBE ALGO PARA BUSCAR...">
    </div>

    <div class="table-responsive">
        <table id="tablaAdmin" class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Equipo</th>
                    <th>Integrante</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                <% miembros.forEach(miembro => { %>
                    <tr class="fila">
                        <td><%= miembro.nombre_equipo %></td>
                        <td><%= miembro.integrante %></td>
                        <td>
                            <form action="/admin/miembros_equipo/eliminar" method="POST" onsubmit="return confirmarEliminar('<%= miembro.integrante %>')">
                                <input type="hidden" name="nombre_equipo" value="<%= miembro.nombre_equipo %>">
                                <input type="hidden" name="integrante" value="<%= miembro.integrante %>">
                                <button class="btn btn-danger btn-sm w-100" type="submit">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</div>
</section>
</main>

<script src="/assets/bootstrap/js/bootstrap.bundle.min.js"></script>

<script>
function confirmarEliminar(nombre) {
    return confirm(`¿Estás seguro que quieres eliminar a este miembro: ${nombre}?`);
}

function cerrarAlerta() {
    const alerta = document.getElementById('mensaje-alerta');
    if (alerta) alerta.remove();

    if (window.location.search.includes('mensaje=')) {
        window.history.replaceState({}, document.title, window.location.pathname);
    }
}

const buscar = document.getElementById('buscar');
if (buscar) {
    buscar.addEventListener('keyup', function () {
        const texto = this.value.toLowerCase();
        document.querySelectorAll('.fila').forEach(fila => {
            fila.style.display = fila.innerText.toLowerCase().includes(texto) ? '' : 'none';
        });
    });
}

const alerta = document.getElementById('mensaje-alerta');
if (alerta) setTimeout(cerrarAlerta, 3000);
</script>

    <%- include('../partials/scripts') %>
</body>
</html>