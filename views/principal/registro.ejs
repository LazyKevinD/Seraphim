<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Registro - SERAPHIM</title>

    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fuente.css">
</head>

<body style="background:#000;min-height:100vh;">

    <main class="d-flex justify-content-center align-items-center"
          style="min-height:100vh;background:url('/assets/img/Seraphim/Banner_Vacio.jpeg') center / cover no-repeat;">

        <div class="card shadow-lg"
             style="width:420px;border-radius:20px;background:rgba(255,255,255,0.95);">

            <div class="card-body p-4">

                <div class="text-center mb-3">
                    <img src="/assets/img/Seraphim/Logo1.png"
                         style="width:85px;height:85px;">

                    <h2 class="mt-2"
                        style="font-weight:bold;color:#000;">
                        SERAPHIM
                    </h2>

                    <p class="text-muted">
                        Crear nueva cuenta
                    </p>
                </div>

                <% if (mensaje) { %>
                    <div class="alert alert-danger">
                        <%= mensaje %>
                    </div>
                <% } %>

                <form action="/registro" method="POST">

                    <div class="mb-3">
                        <label class="form-label" for="usuario">
                            Usuario
                        </label>

                        <input class="form-control"
                            id="usuario"
                            name="usuario"
                            type="text"
                            value="<%= typeof usuario !== 'undefined' ? usuario : '' %>"
                            >
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="password">
                            Contraseña
                        </label>

                        <input class="form-control"
                               id="password"
                               name="password"
                               type="password"
                               >
                    </div>

                    <div class="mb-3">
                        <label class="form-label"
                               for="confirmarPassword">
                            Confirmar contraseña
                        </label>

                        <input class="form-control"
                               id="confirmarPassword"
                               name="confirmarPassword"
                               type="password"
                               >
                    </div>

                    <div class="alert alert-info mt-3" style="font-size: 0.9rem;">
                        <strong>Requisitos:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Usuario: mínimo 4 caracteres.</li>
                            <li>Usuario: solo letras y números.</li>
                            <li>Contraseña: mínimo 6 caracteres.</li>
                            <li>Contraseña: debe incluir una letra mayúscula.</li>
                            <li>Contraseña: debe incluir un número.</li>
                            <li>Contraseña: debe incluir un carácter especial (!@#$%&*, etc.).</li>
                            <li>No se permiten espacios.</li>
                        </ul>
                    </div>

                    <button class="btn btn-dark w-100"
                            type="submit">
                        CREAR CUENTA
                    </button>

                </form>

                <div class="text-center mt-3">
                    <p class="mb-1">
                        ¿Ya tienes cuenta?
                    </p>

                    <a href="/login"
                       style="color:#000;font-weight:bold;text-decoration:none;">
                        Iniciar sesión
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a href="/"
                       style="color:#000;font-weight:bold;text-decoration:none;">
                        Volver al inicio
                    </a>
                </div>

            </div>
        </div>

    </main>

    <script src="/assets/bootstrap/js/bootstrap.bundle.min.js"></script>

</body>
</html>