<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login - SERAPHIM</title>
    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/css/fuente.css">
</head>

<body style="background:#000;min-height:100vh;">
    <main class="d-flex justify-content-center align-items-center" style="min-height:100vh;background:url('/assets/img/Seraphim/Banner_Vacio.jpeg') center / cover no-repeat;">
        <div class="card shadow-lg" style="width:380px;border-radius:20px;background:rgba(255,255,255,0.95);">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <img src="/assets/img/Seraphim/Logo1.png" style="width:85px;height:85px;">
                    <h2 class="mt-2" style="font-weight:bold;color:#000;">SERAPHIM</h2>
                    <p class="text-muted">Acceso al sistema</p>
                </div>

                <% if (mensaje) { %>
                    <div class="alert alert-danger">
                        <%= mensaje %>
                    </div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label" for="usuario">Usuario</label>
                        <input class="form-control" 
                            id="usuario" 
                            name="usuario" 
                            type="text" 
                            value="<%= typeof usuario !== 'undefined' ? usuario : '' %>"
                            >
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="password">Contraseña</label>
                        <input class="form-control" 
                            id="password" 
                            name="password" 
                            type="password" 
                            value="<%= typeof password !== 'undefined' ? password : '' %>"
                            >
                    </div>
                    <div class="g-recaptcha" data-sitekey="6Lf4MgctAAAAANGtbvlE_l48LnPQ_Vw1u2Y7wy0v"></div>

                    <button class="btn btn-dark w-100" type="submit">ENTRAR</button>
                    
                </form>

                <form action="/login/invitado" method="POST" class="mt-3">
                    <button class="btn btn-outline-dark w-100" type="submit">ENTRAR COMO INVITADO</button>
                </form>

                <div class="text-center mt-2">
                    <a href="/registro"
                       style="color:#000;font-weight:bold;text-decoration:none;">
                        Registrarse
                    </a>
                </div>
                

                <div class="text-center mt-3">
                    <a href="/" style="color:#000;font-weight:bold;text-decoration:none;">Volver al inicio</a>
                </div>
            </div>
        </div>
    </main>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

    <script src="/assets/bootstrap/js/bootstrap.bundle.min.js"></script>
    
</body>
</html>